# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.env

# ============================================================
# 隔离 Python 环境 (章程 VIII)
# 必须使用 .venv/ 项目独立环境, 不允许入库
# ============================================================
.venv/
venv/
env/
ENV/
.python-version

# ============================================================
# 测试与构建产物
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/
*.egg

# ============================================================
# 数据集大文件 (不入库)
# ============================================================
data/raw/**
data/clips/**
data/bmn_inputs/
# 上游 anet_prop.py 硬编码 'data/bmn/BMN_Test_results/auc_result.txt' 输出目录
data/bmn/

# ============================================================
# 章程 IV 反向规则: data/splits/ 下的划分文件**必须**入库
# 这些是数据完整性的版本化产物, 严禁被以上 data/ 通配排除
# ============================================================
!data/splits/
!data/splits/**
!data/splits/.gitkeep

# 但是 splits 目录里的临时缓存仍然不入库
data/splits/*.cache
data/splits/.tmp/
data/splits/.last_class_table.json   # T069 sentinel, 仅本地比较用

# ============================================================
# 实验输出 (章程 II)
# 每次 train/eval 产生的目录大且不可复现单纯靠源码, 不入库
# manifest 四元组可以从 commit/config_hash 重建, 故无需入库
# ============================================================
experiments/**

# 但保留 .gitkeep 让目录存在
!experiments/.gitkeep

# ============================================================
# 推理产物 (长视频可视化输出)
# ============================================================
outputs/

# ============================================================
# 编辑器 / IDE
# ============================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# 日志与临时
# ============================================================
*.log
# PaddleVideo 上游运行时在工作目录产出 .log.txt; 不入库
.log.txt
*.tmp
.cache/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# 模型权重 (除了 experiments/ 内的, 也排除根目录散落的)
# ============================================================
*.pdparams
*.pdopt
*.pdmodel

# 但 third_party/PaddleVideo/ 的 submodule 内权重由 submodule 自己管
# (本仓库不会追踪 submodule 内的具体文件, 只追踪 submodule 指针)

# ============================================================
# 系统 / 包管理器临时
# ============================================================
pip-wheel-metadata/
.eggs/
