# ============================================================
# .env.example — 复制为 `.env` 并填入真实值; `.env` 已在 .gitignore 中
# ============================================================
# 本文件入库, 描述本项目所需的环境变量结构. 不含任何 secret.

# ---- GitHub (用于 git push 远程仓库, 见 README) ----
github_token=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- 腾讯云 COS (用于 US6 BMN 时序定位主线; 见 research.md R8) ----
# 凭据请到腾讯云控制台 → 访问管理 → API 密钥 申请 (推荐子账号 + 最小权限).
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name-1234567890
COS_SECRET_ID=<your-tencent-cos-secret-id>
COS_SECRET_KEY=<your-tencent-cos-secret-key>
COS_VIDEO_PREFIX=pp_video
